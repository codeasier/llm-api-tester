{
  "name": "llm-api-tester",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:web": "vite build --emptyOutDir",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "format:check": "cargo fmt --all --check --manifest-path src-tauri/Cargo.toml",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build:web && pnpm run format:check && pnpm run check:rust && pnpm run lint:rust",
    "build:macos": "pnpm run verify && pnpm tauri build",
    "build:win": "node ./scripts/build-placeholder.mjs win",
    "build:linux": "node ./scripts/build-placeholder.mjs linux"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@monaco-editor/react": "^4.7.0",
    "react-router-dom": "^7.1.0",
    "zustand": "^5.0.0",
    "lucide-react": "^0.460.0",
    "sonner": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.0.0",
    "vitest": "^3.1.2"
  }
}
